rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    // ── Default deny ──────────────────────────────────────────────────────────
    match /{document=**} {
      allow read, write: if false;
    }

    // ── Helpers ───────────────────────────────────────────────────────────────

    function isSignedIn() {
      return request.auth != null;
    }

    // Legge il profilo dell'utente corrente e verifica che deviceId
    // sia nel suo array .devices. Funziona sia per owner che per member
    // (entrambi hanno il deviceId nel proprio profilo dopo il pairing/share).
    function userOwnsDevice(deviceId) {
      return isSignedIn() &&
        deviceId in get(
          /databases/$(database)/documents/users/$(request.auth.uid)
        ).data.devices;
    }

    // FIX #1 — helper per verificare se claimedAt è già stato settato.
    // Restituisce true se il device è già reclamato da qualcuno.
    // Usato per rendere claimedAt immutabile dopo il primo pairing.
    function deviceAlreadyClaimed(deviceId) {
      let d = get(/databases/$(database)/documents/devices/$(deviceId)).data;
      return d.keys().hasAll(['claimedAt']) && d.claimedAt != null;
    }


    // ── USERS ─────────────────────────────────────────────────────────────────

    match /users/{userId} {

      allow get: if isSignedIn() && request.auth.uid == userId;

      // FIX #3 — verifica che uid nel documento corrisponda all'UID Auth reale,
      // e che devices sia un array vuoto al momento della creazione.
      allow create: if isSignedIn()
        && request.auth.uid == userId
        && request.resource.data.keys().hasAll(['uid', 'email', 'devices'])
        && request.resource.data.uid == request.auth.uid
        && request.resource.data.devices is list
        && request.resource.data.devices.size() == 0;   // FIX #5

      // Un utente può aggiornare solo displayName e il proprio array devices.
      // L'aggiunta del deviceId di un member al suo profilo avviene lato server
      // tramite Admin SDK (Cloud Function shareDevice) — non da client.
      allow update: if isSignedIn()
        && request.auth.uid == userId
        && request.resource.data.diff(resource.data).affectedKeys()
            .hasOnly(['displayName', 'devices']);

      allow delete: if false;
    }


    // ── MEMBERS (subcollection del profilo owner) ──────────────────────────────

    match /users/{ownerId}/members/{memberUid} {
      // L'owner legge/scrive/cancella la propria lista di member
      allow read, write: if isSignedIn() && request.auth.uid == ownerId;

      // Un member può leggere solo la propria entry (per conoscere ruolo e device)
      allow get: if isSignedIn() && request.auth.uid == memberUid;

      // I member non possono modificare né cancellare la propria entry
      allow update, delete: if isSignedIn() && request.auth.uid == ownerId;
    }


    // ── DEVICES ───────────────────────────────────────────────────────────────

    match /devices/{deviceId} {

      // Lettura solo per chi ha il device nel proprio profilo
      allow get: if userOwnsDevice(deviceId);

      // List disabilitato: si accede sempre per ID specifico dall'array utente
      allow list: if false;

      // Creazione solo via Admin SDK (ESP32 pipeline)
      allow create: if false;

      // FIX #1 — Update:
      //  - name e settings: sempre modificabili da chi ha accesso
      //  - claimedAt: scrivibile UNA SOLA VOLTA (solo se ancora null/assente)
      //    Dopo il primo pairing diventa immutabile da client.
      allow update: if userOwnsDevice(deviceId)
        && (
          request.resource.data.diff(resource.data).affectedKeys()
              .hasOnly(['name', 'settings'])
          ||
          (
            request.resource.data.diff(resource.data).affectedKeys()
                .hasOnly(['name', 'settings', 'claimedAt'])
            && !deviceAlreadyClaimed(deviceId)
          )
        );

      allow delete: if false;


      // ── History subcollection ────────────────────────────────────────────────

      match /history/{recordId} {
        allow read: if userOwnsDevice(deviceId);
        allow write: if false;   // solo Admin SDK
      }


      // ── Alerts subcollection ─────────────────────────────────────────────────

      match /alerts/{alertId} {
        allow read: if userOwnsDevice(deviceId);

        // FIX #4 — il client può solo impostare isRead = true,
        // non ripristinare a false né toccare altri campi.
        allow update: if userOwnsDevice(deviceId)
          && request.resource.data.diff(resource.data).affectedKeys()
              .hasOnly(['isRead'])
          && request.resource.data.isRead == true;

        allow create, delete: if false;   // solo Admin SDK
      }
    }

  }
}
